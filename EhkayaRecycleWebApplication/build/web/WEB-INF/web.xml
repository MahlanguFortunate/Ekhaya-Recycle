<?xml version="1.0" encoding="UTF-8"?>
<web-app version="3.1" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd">
    <context-param>
        <param-name>mapbox.access.token</param-name>
        <param-value>YOUR_MAPBOX_API_KEY</param-value>
    </context-param>
    <listener>
        <listener-class>za.ac.tut.web.MapboxConfigListener</listener-class>
    </listener>
    <!-- Servlets -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>za.ac.tut.web.LoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>za.ac.tut.web.RegisterServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>za.ac.tut.web.LogoutServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>PickupRequestServlet</servlet-name>
        <servlet-class>za.ac.tut.web.PickupRequestServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>WasteScanServlet</servlet-name>
        <servlet-class>za.ac.tut.web.WasteScanServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DeclineRequestServlet</servlet-name>
        <servlet-class>za.ac.tut.web.DeclineRequestServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AcceptRequestServlet</servlet-name>
        <servlet-class>za.ac.tut.web.AcceptRequestServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RequestDetailsServlet</servlet-name>
        <servlet-class>za.ac.tut.web.RequestDetailsServlet</servlet-class>
    </servlet>
    <!-- Servlet Mappings -->
    <servlet>
        <servlet-name>UpdateProfileServlet</servlet-name>
        <servlet-class>za.ac.tut.web.UpdateProfileServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AIDashboardServlet</servlet-name>
        <servlet-class>za.ac.tut.web.AIDashboardServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>SmartCityAnalyticsApiServlet</servlet-name>
        <servlet-class>za.ac.tut.web.analytics.SmartCityAnalyticsApiServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>FindNearestCentreServlet</servlet-name>
        <servlet-class>za.ac.tut.web.FindNearestCentreServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CentreApprovalServlet</servlet-name>
        <servlet-class>za.ac.tut.web.CentreApprovalServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ConfirmPickupServlet</servlet-name>
        <servlet-class>za.ac.tut.web.ConfirmPickupServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>GeocodeAllCentresServlet</servlet-name>
        <servlet-class>za.ac.tut.web.GeocodeAllCentresServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ResetPasswordServlet</servlet-name>
        <servlet-class>za.ac.tut.web.ResetPasswordServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DeleteAccountServlet</servlet-name>
        <servlet-class>za.ac.tut.web.DeleteAccountServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>UserReportPdfServlet</servlet-name>
        <servlet-class>za.ac.tut.web.UserReportPdfServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AdminSystemReportPdfServlet</servlet-name>
        <servlet-class>za.ac.tut.web.AdminSystemReportPdfServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/RegisterServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/LogoutServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>PickupRequestServlet</servlet-name>
        <url-pattern>/PickupRequestServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>WasteScanServlet</servlet-name>
        <url-pattern>/WasteScanServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DeclineRequestServlet</servlet-name>
        <url-pattern>/DeclineRequestServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AcceptRequestServlet</servlet-name>
        <url-pattern>/AcceptRequestServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RequestDetailsServlet</servlet-name>
        <url-pattern>/RequestDetailsServlet.do</url-pattern>
    </servlet-mapping>
    <!-- Welcome File List -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
        <welcome-file>login.html</welcome-file>
    </welcome-file-list>
    <!-- Session Configuration -->
    <servlet-mapping>
        <servlet-name>UpdateProfileServlet</servlet-name>
        <url-pattern>/UpdateProfileServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AIDashboardServlet</servlet-name>
        <url-pattern>/AIDashboardServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>SmartCityAnalyticsApiServlet</servlet-name>
        <url-pattern>/api/ai-analytics</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>FindNearestCentreServlet</servlet-name>
        <url-pattern>/FindNearestCentreServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CentreApprovalServlet</servlet-name>
        <url-pattern>/CentreApprovalServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ConfirmPickupServlet</servlet-name>
        <url-pattern>/ConfirmPickupServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>GeocodeAllCentresServlet</servlet-name>
        <url-pattern>/GeocodeAllCentresServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ResetPasswordServlet</servlet-name>
        <url-pattern>/ResetPasswordServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DeleteAccountServlet</servlet-name>
        <url-pattern>/DeleteAccountServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UserReportPdfServlet</servlet-name>
        <url-pattern>/UserReportPdfServlet.do</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AdminSystemReportPdfServlet</servlet-name>
        <url-pattern>/AdminSystemReportPdfServlet.do</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
    <!-- Error Pages -->
    <error-page>
        <error-code>404</error-code>
        <location>/error_404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/error_500.jsp</location>
    </error-page>
    <welcome-file-list>
    <welcome-file>index.html</welcome-file>
    <welcome-file>login.html</welcome-file>
</welcome-file-list>
</web-app>